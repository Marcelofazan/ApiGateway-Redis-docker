{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/{version}/agrupador",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "sistema.agrupador.api",
          "Port": 443
        }
      ],
      "UpstreamPathTemplate": "/agrupador-api/{version}/agrupador",
      "UpstreamHttpMethod": [ "POST" ],
      "DangerousAcceptAnyServerCertificateValidator": true
    },
    {
      "DownstreamPathTemplate": "/api/{version}/agrupador/pessoa/{pessoaId}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "sistema.agrupador.api",
          "Port": 443
        }
      ],
      "UpstreamPathTemplate": "/agrupador-api/{version}/agrupador/pessoa/{pessoaId}",
      "UpstreamHttpMethod": [ "GET" ],
      "DangerousAcceptAnyServerCertificateValidator": true
    },
    {
      "DownstreamPathTemplate": "/api/{version}/produtos",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "sistema.produto.api",
          "Port": 443
        }
      ],
      "UpstreamPathTemplate": "/produto-api/{version}/produtos",
      "UpstreamHttpMethod": [ "GET" ],
      "DangerousAcceptAnyServerCertificateValidator": true
    },
    {
      "DownstreamPathTemplate": "/api/{version}/pessoas",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "sistema.pessoa.api",
          "Port": 443
        }
      ],
      "UpstreamPathTemplate": "/pessoa-api/{version}/pessoas",
      "UpstreamHttpMethod": [ "GET" ],
      "DangerousAcceptAnyServerCertificateValidator": true
    },
    {
      "DownstreamPathTemplate": "/api/{version}/{everthing}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "host.docker.internal",
          "Port": 1000
        }
      ],
      "UpstreamPathTemplate": "/api/{version}/{everthing}",
      "UpstreamHttpMethod": [ "GET", "Post" ],
      "DangerousAcceptAnyServerCertificateValidator": true
    }
  ],
  "GlobalConfiguration": {
    "RequestIdKey": "OcRequestId",
    "AdministrationPath": "/administration"
  }
}
